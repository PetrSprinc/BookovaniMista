@section Styles {
    <style>
        /* SVG sekce */
        .section { fill:#0d6efd22; stroke:#0d6efd; stroke-width:2; cursor:pointer; transition:fill .12s, transform .08s; }
        a .section:hover { fill:#0d6efd55; transform: scale(1.01); }
        .label { fill:#0d6efd; font-weight:700; font-size:24px; pointer-events:none; }

        /* Overlay detailu (CSS-only: :target) */
        .overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); align-items:center; justify-content:center; z-index:1050; padding:1rem; }
        .overlay:target { display:flex; }
        .detail { background:#fff; padding:1.25rem; border-radius:.5rem; max-width:760px; width:100%; box-shadow:0 8px 24px rgba(0,0,0,.2); position:relative; }
        .detail .close { position:absolute; right:.5rem; top:.25rem; font-size:2rem; color:#666; text-decoration:none; line-height:1; }
        .detail .muted { color:#6c757d; margin-top:-.25rem; margin-bottom:.75rem; }

        /* Grid míst 3x4 */
        .seats-grid { display:grid; grid-template-columns:repeat(3, 1fr); gap:.5rem; margin-top:.75rem; }
        .seat { min-height:48px; display:flex; align-items:center; justify-content:center; font-weight:600; }
    </style>
}
