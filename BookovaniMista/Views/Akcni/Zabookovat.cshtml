@{
    ViewData["Title"] = "Zabookovat místo";
}
<h1>@ViewData["Title"]</h1>

<p class="lead">Možnost zabookvat jedno místo pro zvolený den. Klikněte na sekci mapy pro detail.</p>

<div class="card mb-4">
    <div class="card-body">
        <p>Klikněte na sekci mapy pro zobrazení detailu (bez JavaScriptu).</p>

        <div class="ratio ratio-16x9">
            <svg viewBox="0 0 1000 500" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;">
                <!-- Horní řada: 4 sekce-->
                <a href="#section-1"><rect x="20"  y="20"  width="220" height="200" class="section" data-id="1" /></a>
                <a href="#section-2"><rect x="260" y="20"  width="220" height="200" class="section" data-id="2" /></a>
                <a href="#section-3"><rect x="500" y="20"  width="220" height="200" class="section" data-id="3" /></a>
                <a href="#section-4"><rect x="740" y="20"  width="220" height="200" class="section" data-id="4" /></a>

                <!-- Dolní řada: 5 sekcí -->
                <a href="#section-5"><rect x="20"  y="260" width="150" height="200" class="section" data-id="5" /></a>
                <a href="#section-6"><rect x="190" y="260" width="150" height="200" class="section" data-id="6" /></a>
                <a href="#section-7"><rect x="360" y="260" width="150" height="200" class="section" data-id="7" /></a>
                <a href="#section-8"><rect x="530" y="260" width="150" height="200" class="section" data-id="8" /></a>
                <a href="#section-9"><rect x="700" y="260" width="150" height="200" class="section" data-id="9" /></a>

                <!-- Štítky-->
                <a href="#section-1"><text x="130" y="120" text-anchor="middle" class="label">1</text></a>
                <a href="#section-2"><text x="370" y="120" text-anchor="middle" class="label">2</text></a>
                <a href="#section-3"><text x="610" y="120" text-anchor="middle" class="label">3</text></a>
                <a href="#section-4"><text x="850" y="120" text-anchor="middle" class="label">4</text></a>

                <a href="#section-5"><text x="95"  y="360" text-anchor="middle" class="label">5</text></a>
                <a href="#section-6"><text x="265" y="360" text-anchor="middle" class="label">6</text></a>
                <a href="#section-7"><text x="435" y="360" text-anchor="middle" class="label">7</text></a>
                <a href="#section-8"><text x="605" y="360" text-anchor="middle" class="label">8</text></a>
                <a href="#section-9"><text x="775" y="360" text-anchor="middle" class="label">9</text></a>
            </svg>
        </div>
    </div>
</div>

<!-- Detailní panely pro každou sekci-->
<div id="section-1" class="overlay" aria-hidden="true">
    <div class="detail">
        <a class="close" href="#" aria-label="Zavřít">&times;</a>
        <h3>Sekce 1</h3>
        <p class="muted">Severní levá sekce — vizualizace míst (3×4)</p>
        <div class="seats-grid">
            @for (int r = 1; r <= 4; r++)
            {
                for (int c = 1; c <= 3; c++)
                {
                    <button type="button" class="btn btn-outline-primary seat">R@rC@c</button>
                }
            }
        </div>
    </div>
</div>

